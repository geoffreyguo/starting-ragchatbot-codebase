# Copy this file to .env and add your actual API key

# LLM API settings (OpenAI-compatible, works with OpenAI, Azure, and many third-party endpoints)
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.openai.com/v1  # Change for third-party endpoints
LLM_MODEL=gpt-4o-mini  # Change to your model name